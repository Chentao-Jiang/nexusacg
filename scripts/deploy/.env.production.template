# NexusACG Production Environment Configuration
# Copy this file to .env.production and fill in all values before deploying

# --- Application ---
ENV=production
PORT=8080
BASE_URL=https://your-domain.com

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=nexusacg
DB_USER=nexusacg
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSLMODE=disable

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_BASE64_64

# --- AI Content Moderation ---
DEEPSEEK_API_KEY=sk-xxxxx
QWEN_API_KEY=sk-xxxxx

# --- Alipay ---
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_APP_PRIVATE_KEY_PATH=/app/keys/alipay_app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/keys/alipay_public_key.pem
ALIPAY_SANDBOX=false

# --- WeChat OAuth ---
WECHAT_OAUTH_APP_ID=
WECHAT_OAUTH_APP_SECRET=

# --- WeChat Pay ---
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APIV3_KEY=
WECHAT_PAY_CERT_SERIAL=
WECHAT_PAY_PRIVATE_KEY_PATH=/app/keys/wechat_pay_private_key.pem

# --- QQ OAuth ---
QQ_OAUTH_APP_ID=
QQ_OAUTH_APP_KEY=

# --- SMS (Aliyun) ---
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=次元链
SMS_TEMPLATE_CODE=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@nexusacg.com

# --- Order Management ---
ORDER_TIMEOUT_MINUTES=30
AUTO_RELEASE_DAYS=7
