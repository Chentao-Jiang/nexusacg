# NexusACG Environment Configuration
# Copy this file to .env and fill in the values

# --- Application ---
ENV=development
PORT=8080
BASE_URL=http://localhost:8080

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=nexusacg
DB_USER=nexusacg
DB_PASSWORD=nexusacg_dev_pass

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=change-this-to-a-secure-random-string

# --- Alipay (smartwalle/alipay SDK) ---
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY_PATH=/app/alipay_app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/alipay_public_key.pem
ALIPAY_SANDBOX=true

# --- WeChat Pay (API v3) — uncomment and fill if using WeChat Pay ---
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_APIV3_KEY=
# WECHAT_PAY_CERT_SERIAL=
# WECHAT_PAY_PRIVATE_KEY_PATH=/app/wechat_pay_private_key.pem

# --- AI Content Moderation (Alibaba Cloud) ---
MODERATION_API_KEY=
MODERATION_API_SECRET=

# --- Order Timeout ---
ORDER_TIMEOUT_MINUTES=30
